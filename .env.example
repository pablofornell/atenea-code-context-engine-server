# Atenea Server configuration
# Copy this file to .env and edit the values.
# .env is never committed to git.

# Network
HOST=0.0.0.0
PORT=8443

# Encryption (AES-256-GCM) — must match ATENEA_SECRET on the client
ATENEA_SECRET=change-me-to-a-strong-random-secret

# Ollama
# OLLAMA_URL=http://localhost:11434
# EMBEDDING_MODEL=nomic-embed-text

# Qdrant
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# Logging (DEBUG, INFO, WARNING, ERROR)
# ATENEA_LOG_LEVEL=INFO

